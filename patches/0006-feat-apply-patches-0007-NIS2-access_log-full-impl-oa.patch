+"""Tests for the NIS2 access log middleware.
+
+Covers:
+  - _classify_action: all NIS2 action categories (auth, user, group, config,
+    tasks, automations, calendar, skills, pipelines, SCIM, channels, …)
+  - _NIS2_SECURITY_ACTIONS membership (nis2=Y flag)
+  - _extract_object_ref: URL → (type, id) extraction
+  - _outcome_from_status: HTTP status → outcome string
+  - log_scheduled_activity: format, fields, meta, nis2=Y level
+  - invalidate_user_cache: cache eviction
+"""
+
+import logging
+import pytest
+from unittest.mock import patch, MagicMock
+
+from open_webui.middleware.access_log import (
+    _classify_action,
+    _NIS2_SECURITY_ACTIONS,
+    _extract_object_ref,
+    _outcome_from_status,
+    log_scheduled_activity,
+    invalidate_user_cache,
+    _cache_data,
+    _cache_lock,
+    _UserContext,
