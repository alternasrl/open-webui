+# Helpers
+# ---------------------------------------------------------------------------
+
+def classify(method: str, path: str):
+    """Thin wrapper that returns (action, is_security) for a given request."""
+    return _classify_action(method, path)
+
+
+def action_of(method: str, path: str) -> str:
+    return classify(method, path)[0]
+
+
+def is_nis2(method: str, path: str) -> bool:
+    return classify(method, path)[1]
+
+
