From: Fabio Paracchini <fparacchini@alteanet.it>
Date: Tue, 10 Mar 2026 22:57:29 +0100
Subject: [PATCH 12/21] fix: await save handlers before dispatching save event;
 propagate async through connection modal chain

---
 src/lib/apis/openai/index.ts                  |  7 ++++--
 .../admin/Settings/Connections.svelte         | 22 +++++++++++--------
 .../Connections/OllamaConnection.svelte       |  4 ++--
 .../Connections/OpenAIConnection.svelte       |  4 ++--
 4 files changed, 22 insertions(+), 15 deletions(-)

diff --git a/src/lib/apis/openai/index.ts b/src/lib/apis/openai/index.ts
index 90032fdfc..3d0235743 100644
--- a/src/lib/apis/openai/index.ts
+++ b/src/lib/apis/openai/index.ts
@@ -261,11 +261,14 @@ export const getOpenAIModels = async (token: string, urlIdx?: number) => {
 		}
 	)
 		.then(async (res) => {
-			if (!res.ok) throw await res.json();
+			if (!res.ok) {
+				const body = await res.json().catch(() => null);
+				throw body ?? { message: `HTTP ${res.status}` };
+			}
 			return res.json();
 		})
 		.catch((err) => {
-			error = `OpenAI: ${err?.error?.message ?? 'Network Problem'}`;
+			error = `OpenAI: ${err?.error?.message ?? err?.message ?? 'Network Problem'}`;
 			return [];
 		});
 
diff --git a/src/lib/components/admin/Settings/Connections.svelte b/src/lib/components/admin/Settings/Connections.svelte
