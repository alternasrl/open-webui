+                    'TASK_AUTOMATION_SCHEDULED_ERROR',
+                    'unknown', 'unknown',
+                    automation.id, 'automation',
+                    500, 0.0,
+                    meta=f'trigger={trigger}|name={automation.name}|error=user_not_found',
+                )
